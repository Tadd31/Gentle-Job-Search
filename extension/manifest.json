{
  "manifest_version": 3,
  "name": "The Job Scout Clipper",
  "version": "1.0.0",
  "description": "Clip job boards and career pages directly to your Job Scout.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "host_permissions": ["*://*/*"]
}
